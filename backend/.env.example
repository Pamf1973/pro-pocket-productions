# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/pocketproductions"

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ─── OpenRouter AI (text generation — gpt-4o-mini) ───────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."

# ─── OpenAI (DALL-E 3 image generation only) ──────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="pocket-productions-media"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Dev Bypass (set true to skip Clerk auth during local development) ────────
BYPASS_AUTH=true
